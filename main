// ══════════════════════════════════════════ STATE
let currentScreen = 0;
let selectedEvent = null;
let selectedStarter = "";
let selectedInterests = new Set();
let selectedBigQ = null;
let starRating = 0;
const TOTAL_STEPS = 7; // 0-6

// ══════════════════════════════════════════ INIT
function init() {
  // ── Build category filter bar
  const fb = document.getElementById('filter-bar');
  CATEGORIES.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'filter-btn' + (cat.id === 'all' ? ' active' : '');
    btn.textContent = cat.label;
    btn.dataset.cat = cat.id;
    btn.onclick = () => filterEvents(cat.id);
    fb.appendChild(btn);
  });

  // ── Build events grid grouped by category
  const grid = document.getElementById('events-grid');
  const catColors = {};
  CATEGORIES.forEach(c => { catColors[c.id] = c.color; });

  let lastCat = null;
  EVENTS.forEach((e, i) => {
    // Insert category header when category changes
    if (e.cat !== lastCat) {
      const catInfo = CATEGORIES.find(c => c.id === e.cat);
      if (catInfo) {
        const header = document.createElement('div');
        header.className = 'cat-header';
        header.dataset.cat = e.cat;
        header.innerHTML = `
          <span class="cat-header-label" style="background:${catInfo.color};">${catInfo.label}</span>
          <div class="cat-header-line"></div>
        `;
        grid.appendChild(header);
      }
      lastCat = e.cat;
    }
    const color = catColors[e.cat] || 'var(--teal)';
    const card = document.createElement('div');
    card.className = 'event-card';
    card.id = 'event-' + i;
    card.dataset.cat = e.cat;
    card.style.borderTop = `3px solid ${color}`;
    card.innerHTML = `
      <span class="event-emoji">${e.emoji}</span>
      <div class="event-year" style="color:${color};">${e.year}</div>
      <div class="event-name">${e.name}</div>
      <div class="event-spark">"${e.spark}"</div>
    `;
    card.onclick = () => selectEvent(i, card);
    grid.appendChild(card);
  });

  // ── Build sources list
  const sl = document.getElementById('sources-list');
  SOURCES.forEach(s => {
    sl.innerHTML += `
      <div class="source-card">
        <div class="source-icon ${s.type}"><span>${s.icon}</span></div>
        <div>
          <div class="source-name">${s.name}</div>
          <div class="source-url">${s.url}</div>
          <div class="source-desc">${s.desc}</div>
        </div>
      </div>
    `;
  });

  // ── Build interest chips
  const ig = document.getElementById('interest-grid');
  INTERESTS.forEach((t, i) => {
    const chip = document.createElement('div');
    chip.className = 'interest-chip';
    chip.textContent = t;
    chip.onclick = () => {
      chip.classList.toggle('selected');
      if (chip.classList.contains('selected')) selectedInterests.add(t);
      else selectedInterests.delete(t);
    };
    ig.appendChild(chip);
  });

  // ── Build big question choices
  const bq = document.getElementById('big-q-choices');
  BIG_QUESTIONS.forEach((q, i) => {
    bq.innerHTML += `
      <label style="display:flex; align-items:flex-start; gap:10px; cursor:pointer; padding:8px; border-radius:8px; transition:background 0.2s; font-size:0.88rem; margin-top:0;">
        <input type="radio" name="bigq" value="${i}" onchange="selectedBigQ=${i}" style="margin-top:3px; accent-color:var(--teal); width:auto; flex-shrink:0;">
        <span>${q}</span>
      </label>
    `;
  });

  buildStepNav();
  updateProgress();
}

// ── Filter events by category
function filterEvents(catId) {
  document.querySelectorAll('.filter-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.cat === catId);
  });
  document.querySelectorAll('.event-card').forEach(card => {
    const matches = catId === 'all' || card.dataset.cat === catId;
    card.classList.toggle('hidden', !matches);
  });
  document.querySelectorAll('.cat-header').forEach(h => {
    const matches = catId === 'all' || h.dataset.cat === catId;
    h.classList.toggle('hidden', !matches);
  });
}

function buildStepNav() {
  const nav = document.getElementById('step-nav');
  // screens 1–5 are the "steps" (0 is welcome, 6 is done)
  for (let i = 1; i <= 5; i++) {
    const dot = document.createElement('div');
    dot.className = 'step-dot';
    dot.id = 'dot-' + i;
    dot.title = 'Step ' + i;
    dot.onclick = () => { if (i < currentScreen || i === currentScreen) goBack(i); };
    nav.appendChild(dot);
  }
}

// ══════════════════════════════════════════ NAVIGATION
function goTo(screen, isBack = false) {
  // Only validate when going FORWARD, never when going back
  if (!isBack && !validateScreen(currentScreen)) return;
  document.getElementById('s' + currentScreen).classList.remove('active');
  currentScreen = screen;
  document.getElementById('s' + screen).classList.add('active');
  updateProgress();
  updateDots();
  window.scrollTo({ top: 0, behavior: 'smooth' });

  // Sync reminders
  if (screen === 2 && selectedEvent !== null) {
    document.getElementById('question-event-reminder').textContent = EVENTS[selectedEvent].name;
  }
  if (screen === 4) {
    const q = buildQuestion();
    document.getElementById('note-question-reminder').textContent = q || '(your question from Step 2)';
  }
}

function goBack(screen) {
  goTo(screen, true);
}

function startApp() {
  const name = document.getElementById('student-name').value.trim();
  if (!name) { showToast('Please enter your name first!'); return; }
  goTo(1);
}

// Auto-advance welcome screen when both name + class are filled
function checkWelcomeComplete() {
  const name = document.getElementById('student-name').value.trim();
  const cls  = document.getElementById('student-class').value.trim();
  if (name && cls && currentScreen === 0) {
    setTimeout(() => {
      // Only auto-advance if still on screen 0
      if (currentScreen === 0) goTo(1);
    }, 400);
  }
}

function updateProgress() {
  const pct = currentScreen === 0 ? 0 : currentScreen === 6 ? 100 : (currentScreen / 5) * 90;
  document.getElementById('progress-bar').style.width = pct + '%';
}

function updateDots() {
  for (let i = 1; i <= 5; i++) {
    const dot = document.getElementById('dot-' + i);
    if (!dot) continue;
    dot.className = 'step-dot';
    if (i < currentScreen) dot.classList.add('done');
    else if (i === currentScreen) dot.classList.add('active');
  }
}

// ══════════════════════════════════════════ VALIDATION
function validateScreen(screen) {
  if (screen === 0) return true; // handled by startApp
  if (screen === 1) {
    if (selectedEvent === null) { showToast('Choose an event from the timeline!'); return false; }
    if (!document.getElementById('why-chosen').value.trim()) { showToast('Tell us why you chose this event'); return false; }
  }
  if (screen === 2) {
    if (!selectedStarter) { showToast('Pick a question starter word'); return false; }
    if (!document.getElementById('question-rest').value.trim()) { showToast('Finish writing your research question'); return false; }
  }
  return true;
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = '⚠ ' + msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ══════════════════════════════════════════ EVENT SELECTION
function selectEvent(i, card) {
  document.querySelectorAll('.event-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
  selectedEvent = i;
}

// ══════════════════════════════════════════ QUESTION BUILDER
function selectStarter(el, word) {
  document.querySelectorAll('.starter-chip').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  selectedStarter = word;
  updateQuestionPreview();
}

function buildQuestion() {
  const rest = document.getElementById('question-rest').value.trim();
  if (!selectedStarter && !rest) return '';
  return (selectedStarter ? selectedStarter + ' ' : '') + rest;
}

function updateQuestionPreview() {
  const q = buildQuestion();
  const preview = document.getElementById('question-preview');
  if (q) {
    preview.textContent = '"' + q + '"';
    preview.style.color = 'var(--ink)';
  } else {
    preview.textContent = 'Your question will appear here as you type...';
    preview.style.color = 'var(--mid)';
  }
}

// ══════════════════════════════════════════ STAR RATING
function rateStar(n) {
  starRating = n;
  document.querySelectorAll('.star').forEach((s, i) => {
    s.classList.toggle('lit', i < n);
  });
}

// ══════════════════════════════════════════ FINISH
function finish() {
  if (!document.getElementById('final-answer').value.trim()) {
    showToast('Write your answer before finishing!');
    return;
  }

  const name = document.getElementById('student-name').value.trim();
  const cls  = document.getElementById('student-class').value.trim();
  const event = selectedEvent !== null ? EVENTS[selectedEvent] : null;
  const question = buildQuestion();

  // Store data globally so copyAnswers() can access it
  window._summary = {
    name, cls, event, question,
    whyChosen:     document.getElementById('why-chosen').value.trim(),
    priorKnowledge:document.getElementById('prior-knowledge').value.trim(),
    src1Name:      document.getElementById('src1-name').value.trim(),
    s1f1:          document.getElementById('s1f1').value.trim(),
    s1f2:          document.getElementById('s1f2').value.trim(),
    s1f3:          document.getElementById('s1f3').value.trim(),
    s1Surprise:    document.getElementById('s1-surprise').value.trim(),
    src2Name:      document.getElementById('src2-name').value.trim(),
    s2f1:          document.getElementById('s2f1').value.trim(),
    s2f2:          document.getElementById('s2f2').value.trim(),
    s2f3:          document.getElementById('s2f3').value.trim(),
    s2Diff:        document.getElementById('s2-diff').value.trim(),
    finalAnswer:   document.getElementById('final-answer').value.trim(),
    stillWondering:document.getElementById('still-wondering').value.trim(),
    interests:     [...selectedInterests],
    bigQ:          selectedBigQ !== null ? BIG_QUESTIONS[selectedBigQ] : '—',
    stars:         starRating,
    oneWord:       document.getElementById('one-word').value.trim(),
  };

  document.getElementById('finish-name').textContent = name;

  // Build visual summary cards — detailed for print
  const s = window._summary;
  const sb = document.getElementById('summary-block');
  sb.innerHTML = `
    <div class="summary-row"><div class="summary-label">Student</div><div class="summary-value">${s.name}${s.cls ? ' &nbsp;·&nbsp; ' + s.cls : ''}</div></div>
    <div class="summary-row"><div class="summary-label">Event I researched</div><div class="summary-value">${s.event ? s.event.emoji + ' &nbsp;<strong>' + s.event.name + '</strong> &nbsp;(' + s.event.year + ')' : '—'}</div></div>
    <div class="summary-row"><div class="summary-label">Why I chose it</div><div class="summary-value">${s.whyChosen || '—'}</div></div>
    <div class="summary-row"><div class="summary-label">My research question</div><div class="summary-value" style="font-style:italic; font-size:1rem;">"${s.question || '—'}"</div></div>
    <div class="summary-row"><div class="summary-label">What I already knew</div><div class="summary-value">${s.priorKnowledge || '—'}</div></div>
    <div class="summary-row">
      <div class="summary-label">Source 1 — ${s.src1Name || '—'}</div>
      <div class="summary-value">
        ${s.s1f1 ? '1. ' + s.s1f1 : ''}${s.s1f2 ? '<br>2. ' + s.s1f2 : ''}${s.s1f3 ? '<br>3. ' + s.s1f3 : ''}
        ${s.s1Surprise ? '<br><em>Surprised me: ' + s.s1Surprise + '</em>' : ''}
      </div>
    </div>
    <div class="summary-row">
      <div class="summary-label">Source 2 — ${s.src2Name || '—'}</div>
      <div class="summary-value">
        ${s.s2f1 ? '1. ' + s.s2f1 : ''}${s.s2f2 ? '<br>2. ' + s.s2f2 : ''}${s.s2f3 ? '<br>3. ' + s.s2f3 : ''}
        ${s.s2Diff ? '<br><em>Different from Source 1: ' + s.s2Diff + '</em>' : ''}
      </div>
    </div>
    <div class="summary-row"><div class="summary-label">My answer to my research question</div><div class="summary-value">${s.finalAnswer || '—'}</div></div>
    <div class="summary-row"><div class="summary-label">I'm still wondering...</div><div class="summary-value">${s.stillWondering || '—'}</div></div>
    <div class="summary-row"><div class="summary-label">Topics I'm interested in</div><div class="summary-value">${s.interests.length > 0 ? s.interests.join(' &nbsp;·&nbsp; ') : '—'}</div></div>
    <div class="summary-row"><div class="summary-label">Big question I'd love to explore</div><div class="summary-value">${s.bigQ}</div></div>
    <div class="summary-row"><div class="summary-label">How I found this task</div><div class="summary-value">${'★'.repeat(s.stars) + '☆'.repeat(5 - s.stars)}${s.oneWord ? ' &nbsp;·&nbsp; "' + s.oneWord + '"' : ''}</div></div>
  `;

  document.getElementById('s5').classList.remove('active');
  currentScreen = 6;
  document.getElementById('s6').classList.add('active');
  updateProgress();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function printSummary() {
  window.print();
}

// ══════════════════════════════════════════ BOOT
init();
</script>
</body>
